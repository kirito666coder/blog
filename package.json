{
  "name": "expo-ecommerce",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "lint": "pnpm exec eslint . && pnpm --dir web exec eslint . && pnpm --dir mobile exec eslint .",
    "lint:fix": "pnpm exec eslint . --fix && pnpm --dir web exec eslint . --fix && pnpm --dir mobile exec eslint . --fix",
    "lint:mobile": "pnpm --dir mobile exec eslint .",
    "lint:web": "pnpm --dir web exec eslint .",
    "format": "prettier . --write",
    "format:check": "prettier . --check"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.2",
    "prettier-plugin-tailwindcss": "^0.7.2"
  },
  "lint-staged": {
    "*.{js,ts,tsx,jsx,cjs,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,yaml.yml}": [
      "prettier --write"
    ]
  }
}
